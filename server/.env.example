# Copy to server/.env and fill in from your Supabase project (Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
PORT=5000
JWT_SECRET=a-random-string
CLIENT_ORIGIN=http://localhost:5173

# Full public URL of the API server (used for OAuth callbacks, etc.).
# In development this defaults to http://localhost:$PORT, but MUST be set
# explicitly in staging/production (e.g. https://api.mysite.com).
API_BASE_URL=http://localhost:5000

# Report generation timezone (defaults to Africa/Cairo)
REPORT_TIMEZONE=Africa/Cairo
